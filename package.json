{
  "name": "@heroku-cli/plugin-data-privatelink",
  "description": "Heroku Data via PrivateLink CLI",
  "version": "1.3.4",
  "author": "Heroku",
  "bugs": "https://github.com/heroku/heroku-data-privatelink-cli/issues",
  "dependencies": {
    "@heroku-cli/color": "^2.0.1",
    "@heroku-cli/command": "^11.5.0",
    "@heroku-cli/schema": "^1.0.25",
    "@oclif/core": "^2.16.0",
    "@oclif/plugin-help": "^5",
    "cli-ux": "^6.0.9",
    "stdout-stderr": "^0.1.13",
    "tslib": "1.14.1"
  },
  "devDependencies": {
    "@oclif/test": "^2.3.28",
    "@types/chai": "^4.3.14",
    "@types/chai-as-promised": "^7.1.8",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.14.8",
    "@types/supports-color": "^8.1.3",
    "chai": "^4.4.1",
    "chai-as-promised": "^7.1.1",
    "eslint": "^9",
    "eslint-config-oclif": "^6.0.144",
    "eslint-plugin-mocha": "^11.2.0",
    "globby": "^10.0.2",
    "lolex": "^3.1.0",
    "mocha": "^11",
    "nock": "^13.5.1",
    "nyc": "^17.1.0",
    "oclif": "^4.22.81",
    "ts-node": "^10.9.2",
    "tsheredoc": "^1.0.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "/lib",
    "/oclif.manifest.json"
  ],
  "homepage": "https://github.com/heroku/heroku-data-privatelink-cli",
  "keywords": [
    "heroku",
    "heroku-cli-plugin"
  ],
  "license": "MIT",
  "mocha": {
    "require": [
      "test/helpers/init.js",
      "ts-node/register",
      "source-map-support/register"
    ],
    "watch-extensions": "ts",
    "recursive": true,
    "reporter": "spec",
    "timeout": 30000
  },
  "oclif": {
    "commands": "./lib/commands",
    "bin": "heroku",
    "plugins": [
      "@oclif/plugin-help"
    ]
  },
  "repository": "heroku/heroku-data-privatelink-cli",
  "scripts": {
    "build": "rm -rf lib && tsc -b",
    "lint": "eslint .",
    "postpack": "rm -f oclif.manifest.json",
    "posttest": "yarn lint",
    "prepack": "rm -rf lib && tsc -b && oclif manifest",
    "pretest": "tsc -p test --noEmit && yarn build",
    "test": "nyc mocha --forbid-only \"test/**/*.unit.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "resolutions": {
    "serialize-javascript": "^7.0.3"
  }
}
